# העתיקו קובץ זה ל-.env ומלאו את הערכים האמיתיים.
# את המפתח מקבלים בחינם ב-Google AI Studio: https://aistudio.google.com/apikey

# מפתח ה-API של Gemini (חובה). נשמר בצד שרת בלבד ואינו נחשף לדפדפן.
GEMINI_API_KEY=your-api-key-here

# הפורט שעליו ירוץ השרת (אופציונלי, ברירת מחדל 3000)
PORT=3000

# מודל Gemini לשימוש (אופציונלי, ברירת מחדל gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
